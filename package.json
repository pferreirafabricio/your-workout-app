{
  "name": "@better-bookkeeping/demo-project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev.sh up",
    "dev:down": "./scripts/dev.sh down",
    "db:migrate": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/demo_project prisma migrate dev",
    "db:reset": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/demo_project prisma migrate reset --force",
    "build": "vite build",
    "serve": "vite preview",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "test": "bun run test:e2e",
    "test:unit": "vitest run",
    "test:integration": "echo 'Integration tests are not implemented yet. Placeholder stage passed.'",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.9.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-devtools": "^0.9.2",
    "@tanstack/react-form": "^1.25.0",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.91.0",
    "@tanstack/react-router": "^1.139.3",
    "@tanstack/react-router-devtools": "^1.139.3",
    "@tanstack/react-router-ssr-query": "^1.139.3",
    "@tanstack/react-start": "^1.139.3",
    "@tanstack/router-plugin": "^1.139.3",
    "bcryptjs": "^3.0.3",
