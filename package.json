    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.26.2",
    "nitro": "^3.0.1-alpha.1",
    "prisma": "^7.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
